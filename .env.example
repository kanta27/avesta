# Avesta Nordic — environment template
# Copy this file to `.env.local` and fill in the values. NEVER commit .env.local
# or any real secret. Only NEXT_PUBLIC_* vars are exposed to the browser; every
# other value is server-only.
#
# Validation lives in lib/env.ts (public) and lib/env.server.ts (server-only).
# Required now: the three NEXT_PUBLIC_* below + SUPABASE_SERVICE_ROLE_KEY (the
# service-role key is validated on first server/admin use, not at boot).
# Everything else is optional until its feature lands.

# ── Site ─────────────────────────────────────────────────────────────────────
# Canonical origin (no trailing slash). Use http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL + anon/publishable key — public-safe, constrained by RLS. REQUIRED.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — BYPASSES RLS. SECRET, server-only. Required for admin /
# webhook / order paths. Supabase Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ── Razorpay (feature A5) ────────────────────────────────────────────────────
# Test keys until go-live; swapping to live keys is an env change, not code.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WhatsApp (feature 10) ────────────────────────────────────────────────────
# Provider: interakt | aisensy. Defaults to interakt if unset.
WHATSAPP_PROVIDER=interakt
WHATSAPP_API_KEY=

# ── Email (receipts) ─────────────────────────────────────────────────────────
# Resend or SES API key for transactional email.
EMAIL_API_KEY=

# ── Analytics (NEXT_PUBLIC — client-exposed) ─────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── Admin & automation ───────────────────────────────────────────────────────
# Comma-separated allow-list for the admin gate (feature A6).
ADMIN_ALLOWED_EMAILS=
# Bearer token for the blog-automation endpoint (feature 16).
AUTOMATION_API_TOKEN=
# Secret protecting the cron routes (feature 9 lead follow-up). Vercel Cron sends
# it automatically as `Authorization: Bearer $CRON_SECRET`. If unset, the cron
# route refuses to run (fail closed). Generate a long random value.
CRON_SECRET=
